{
  "name": "iobroker.marstek-venus",
  "version": "0.1.9",
  "description": "ioBroker adapter for Marstek Venus C/D/E energy storage devices",
  "author": "ioBroker Community",
  "homepage": "https://github.com/Slugger2k/ioBroker.marstek-venus",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "marstek",
    "venus",
    "battery",
    "energy storage",
    "solar",
    "inverter"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Slugger2k/ioBroker.marstek-venus.git"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.1.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
    "@alcalzone/release-script-plugin-license": "^5.1.1",
    "@alcalzone/release-script-plugin-manual-review": "^5.1.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/eslint-config": "^2.2.0",
    "@iobroker/testing": "^5.2.2",
    "@iobroker/types": "^7.1.1",
    "@types/node": "^20.0.0",
    "eslint": "^9.39.4",
    "nyc": "^18.0.0",
    "typescript": "^5.0.0"
  },
  "main": "main.js",
  "files": [
    "admin/",
    "lib/",
    "main.js",
    "io-package.json"
  ],
  "scripts": {
    "test": "npm run test:package && npm run test:unit",
    "release": "release-script",
    "test:package": "mocha test/package.test.js --exit",
    "test:unit": "mocha \"test/*.test.js\" --exit",
    "test:integration": "mocha test/integration.test.js --exit 2>/dev/null || true",
    "coverage": "nyc npm run test",
    "coverage:report": "nyc report --reporter=text --reporter=lcov --reporter=html",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "translate": "translate-adapter"
  },
  "nyc": {
    "all": true,
    "include": [
      "main.js",
      "lib/adapter.js",
      "lib/control.js",
      "lib/discovery.js",
      "lib/polling.js",
      "lib/request-queue.js"
    ],
    "exclude": [
      "test/**",
      "node_modules/**",
      "admin/**",
      "lib/adapter-config.js"
    ],
    "reporter": [
      "text",
      "text-summary",
      "html"
    ],
    "check-coverage": true,
    "branches": 70,
    "functions": 80,
    "lines": 90,
    "statements": 90,
    "extension": [
      ".js"
    ],
    "sourceMap": false,
    "instrument": true
  }
}
