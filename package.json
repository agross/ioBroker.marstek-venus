{
  "name": "iobroker.marstek-venus",
  "version": "0.1.1",
  "description": "ioBroker adapter for Marstek Venus C/D/E energy storage devices",
  "author": {
    "name": "ioBroker Community"
  },
  "homepage": "https://github.com/ioBroker/ioBroker.marstek-venus",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "marstek",
    "venus",
    "battery",
    "energy storage",
    "solar",
    "inverter"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ioBroker/ioBroker.marstek-venus.git"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.0.0"
  },
  "devDependencies": {
    "@iobroker/testing": "^4.0.0",
    "@iobroker/types": "^7.1.1",
    "@types/node": "^20.0.0",
    "chai": "^4.5.0",
    "nyc": "^18.0.0",
    "sinon": "^21.1.0",
    "typescript": "^5.0.0"
  },
  "main": "main.js",
  "files": [
    "admin/",
    "lib/",
    "main.js",
    "io-package.json"
  ],
  "scripts": {
    "test": "npm run test:package && npm run test:unit",
    "test:package": "mocha test/package.test.js --exit",
    "test:unit": "mocha 'test/*.test.js' --exit",
    "test:integration": "mocha test/integration.test.js --exit 2>/dev/null || true",
    "coverage": "nyc npm run test",
    "coverage:report": "nyc report --reporter=text --reporter=lcov --reporter=html"
  },
  "nyc": {
    "all": true,
    "include": [
      "main.js",
      "lib/adapter.js",
      "lib/control.js",
      "lib/discovery.js",
      "lib/polling.js",
      "lib/request-queue.js"
    ],
    "exclude": [
      "test/**",
      "node_modules/**",
      "admin/**",
      "lib/adapter-config.js"
    ],
    "reporter": [
      "text",
      "text-summary",
      "html"
    ],
    "check-coverage": true,
    "branches": 70,
    "functions": 80,
    "lines": 90,
    "statements": 90,
    "extension": [
      ".js"
    ],
    "sourceMap": false,
    "instrument": true
  }
}
