{
  "type": "panel",
  "items": {
    "_header": {
      "type": "header",
      "text": "Marstek Venus Configuration",
      "size": 2
    },
    "_info": {
      "type": "staticText",
      "label": "Pre-requirements: Enable Open API in the official Marstek mobile app first, note the configured UDP port (default: 30000), and ensure device and ioBroker are on the same local network.",
      "newLine": true,
      "xs": 12,
      "sm": 12,
      "md": 12,
      "lg": 12,
      "xl": 12
    },
    "ipAddress": {
      "type": "text",
      "label": "$t:ipAddress",
      "placeholder": "192.168.1.xxx",
      "xs": 12,
      "sm": 6,
      "md": 6,
      "lg": 4,
      "xl": 3,
      "newLine": true
    },
    "udpPort": {
      "type": "number",
      "label": "$t:udpPort",
      "min": 1,
      "max": 65535,
      "default": 30000,
      "xs": 12,
      "sm": 6,
      "md": 6,
      "lg": 4,
      "xl": 3
    },
    "pollInterval": {
      "type": "number",
      "label": "$t:pollInterval",
      "min": 500,
      "max": 60000,
      "default": 10000,
      "xs": 12,
      "sm": 6,
      "md": 6,
      "lg": 4,
      "xl": 3,
      "newLine": true
    },
    "fastPollInterval": {
      "type": "number",
      "label": "$t:fastPollInterval",
      "min": 100,
      "max": 10000,
      "default": 1000,
      "xs": 12,
      "sm": 6,
      "md": 6,
      "lg": 4,
      "xl": 3
    },
    "requestTimeout": {
      "type": "number",
      "label": "$t:requestTimeout",
      "min": 1000,
      "max": 30000,
      "default": 5000,
      "xs": 12,
      "sm": 6,
      "md": 6,
      "lg": 4,
      "xl": 3,
      "newLine": true
    },
    "maxRetries": {
      "type": "number",
      "label": "$t:maxRetries",
      "min": 0,
      "max": 5,
      "default": 1,
      "xs": 12,
      "sm": 6,
      "md": 6,
      "lg": 4,
      "xl": 3
    },
    "autoDiscovery": {
      "type": "checkbox",
      "label": "$t:autoDiscovery",
      "default": true,
      "xs": 12,
      "sm": 12,
      "md": 12,
      "lg": 12,
      "xl": 12,
      "newLine": true
    }
  }
}